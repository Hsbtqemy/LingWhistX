{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "whisperx-studio",
  "version": "0.1.0",
  "identifier": "com.hsemil01.whisperx-studio",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "LingWhistX Studio",
        "width": 1180,
        "height": 820,
        "minWidth": 960,
        "minHeight": 720
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$HOME/**",
          "$TEMP/**",
          "$RESOURCE/**",
          "$APPCACHE/**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": [
      "../python/worker.py",
      "../python/studio_audio_modules.py",
      "../scripts/setup-local-runtime.ps1",
      "../scripts/setup-local-runtime.mjs"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
